# 复制此文件为 .env（本地），按需修改，.env 已被 .gitignore 忽略，不会提交
# ⚠️ 本文件（.env.example）会被 git 追踪，严禁在此写真实凭证
# ───────────────────────────────────────────────────────────

# ── Provider 切换 ──
# ollama    ：本地 Ollama（免费，需 7B 模型约 6GB 内存）
# dashscope ：阿里云百炼（OpenAI 兼容协议）
LLM_PROVIDER=ollama

# ── 模型名（按 provider 不同）──
# ollama    示例：qwen2.5:7b / qwen2.5:3b
# dashscope 示例：qwen-plus / qwen-turbo / qwen-max / qwen-plus-2025-07-28
MODEL_NAME=qwen2.5:7b

# ── 云端凭证（仅 dashscope / openai 需要；ollama 可空着）──
# 占位示例：API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 真实 key 必须只写在本地 .env，绝不在此文件或任何提交物中出现
API_KEY=
API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 通用参数 ──
TEMPERATURE=0
TIMEOUT=60
MAX_ITERATIONS=6
LOG_FILE=logs/app.log

# ── LangSmith 可观测性（可选）──
# 开启后所有 LangChain/LangGraph 调用自动上报 trace 到
#   https://smith.langchain.com/
# 免费额度 5000 traces/月，学习用足够。
#
# 本地开启步骤：把 LANGSMITH_TRACING 改为 true，在本地 .env 里填入真实 API_KEY。
# ⚠️ 真实 key 只写在本地 .env，绝不在此文件或任何提交物中出现
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=java-to-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
